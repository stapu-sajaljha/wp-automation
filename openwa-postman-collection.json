{
  "info": {
    "name": "OpenWA WhatsApp Gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman Collection for OpenWA WhatsApp Gateway API, configured for wa.test.stapubox.com without variables"
  },
  "item": [
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "YOUR_API_KEY",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"testing\"\n}"
            },
            "url": {
              "raw": "https://wa.test.stapubox.com/api/sessions",
              "protocol": "https",
              "host": [
                "wa",
                "test",
                "stapubox",
                "com"
              ],
              "path": [
                "api",
                "sessions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get All Sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "YOUR_API_KEY",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://wa.test.stapubox.com/api/sessions",
              "protocol": "https",
              "host": [
